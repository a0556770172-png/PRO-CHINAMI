rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "e0556770172@gmail.com" || 
         request.auth.token.email == "E0556770172@GMAIL.COM" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isNotBlocked() {
      return isAuthenticated() && 
        (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
         !('isBlocked' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked == false);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email']) &&
             data.uid is string &&
             data.username is string && data.username.size() > 0 && data.username.size() < 100 &&
             data.email is string && data.email.size() < 255 &&
             (!('hasSignedTerms' in data) || data.hasSignedTerms is bool) &&
             (!('signature' in data) || (data.signature is string && data.signature.size() < 200)) &&
             (!('isBlocked' in data) || data.isBlocked is bool) &&
             (!('role' in data) || data.role is string);
    }

    function isValidLink(data) {
      return data.keys().hasAll(['url', 'creatorId', 'remainingUses', 'createdAt']) &&
             data.url is string && data.url.size() > 0 && data.url.size() < 2048 &&
             data.creatorId == request.auth.uid &&
             data.remainingUses is int && data.remainingUses >= 0 && data.remainingUses <= 100 &&
             data.createdAt is string &&
             (!('creatorName' in data) || (data.creatorName is string && data.creatorName.size() < 100)) &&
             (!('isActive' in data) || data.isActive is bool) &&
             (!('likesCount' in data) || data.likesCount is int) &&
             (!('reportsCount' in data) || data.reportsCount is int) &&
             (!('note' in data) || (data.note is string && data.note.size() < 500));
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isAdmin() || isOwner(userId));
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if (isOwner(userId) && isNotBlocked() &&
                    request.resource.data.diff(resource.data).affectedKeys().hasAll(['hasSignedTerms', 'signature']) ||
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hasActiveLink', 'needsToShareBack', 'sharedLinksCount', 'receivedLinksCount', 'username', 'email', 'hasSignedTerms', 'signature'])) ||
                    isAdmin();
    }

    // Links Collection
    match /links/{linkId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNotBlocked() && isValidLink(request.resource.data);
      allow update: if (isAuthenticated() && isNotBlocked() && 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['remainingUses', 'isActive', 'likesCount', 'reportsCount']) ||
                     (resource.data.creatorId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['url', 'note', 'remainingUses', 'isActive'])))) ||
                    isAdmin();
      allow delete: if (isAuthenticated() && isNotBlocked() && resource.data.creatorId == request.auth.uid) || isAdmin();
    }

    // LinkRequests Collection
    match /linkRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNotBlocked() &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.keys().hasAll(['linkId', 'userId', 'requestedAt']);
      allow update: if isAdmin();
    }

    // Feedback Collection
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isNotBlocked() &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.keys().hasAll(['userId', 'type', 'content', 'createdAt']) &&
                    request.resource.data.content is string &&
                    request.resource.data.content.size() > 0 &&
                    request.resource.data.content.size() < 2000 &&
                    request.resource.data.type in ['bug', 'comment', 'request_links'];
      allow update: if isAdmin();
    }

    // Messages Collection
    match /messages/{messageId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.receiverId == request.auth.uid);
      allow create: if isAdmin() || 
                    (isAuthenticated() && isNotBlocked() && 
                     request.resource.data.senderId == request.auth.uid && 
                     request.resource.data.type == 'user_to_admin' &&
                     request.resource.data.content is string &&
                     request.resource.data.content.size() > 0 &&
                     request.resource.data.content.size() < 2000);
      allow update: if isAdmin() || 
                    (isAuthenticated() && resource.data.receiverId == request.auth.uid && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));
      allow delete: if isAdmin();
    }

    // Likes Collection
    match /likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNotBlocked() &&
                    request.resource.data.userId == request.auth.uid &&
                    likeId == request.auth.uid + "_" + request.resource.data.linkId;
      allow delete: if isAuthenticated() && isNotBlocked() && 
                    resource.data.userId == request.auth.uid;
    }

    // Reports Collection
    match /reports/{reportId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isNotBlocked() &&
                    request.resource.data.userId == request.auth.uid &&
                    reportId == request.auth.uid + "_" + request.resource.data.linkId;
    }

    // Site Stats Collection
    match /siteStats/{docId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && isNotBlocked() &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalLinksReceived', 'totalLinksShared', 'activeLinks', 'lastRecalculated']);
      allow write: if isAdmin();
    }
  }
}
