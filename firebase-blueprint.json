{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and sharing status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "hasActiveLink": { "type": "boolean" },
        "needsToShareBack": { "type": "boolean" },
        "sharedLinksCount": { "type": "integer" },
        "receivedLinksCount": { "type": "integer" },
        "isBlocked": { "type": "boolean" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "hasSignedTerms": { "type": "boolean" },
        "signature": { "type": "string" }
      },
      "required": ["uid", "username", "email"]
    },
    "Link": {
      "title": "Link",
      "description": "A shared premium trial link",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "remainingUses": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "likesCount": { "type": "integer" },
        "reportsCount": { "type": "integer" },
        "note": { "type": "string" }
      },
      "required": ["id", "url", "creatorId", "remainingUses", "createdAt"]
    },
    "LinkRequest": {
      "title": "LinkRequest",
      "description": "Record of a user requesting a link",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "linkId": { "type": "string" },
        "userId": { "type": "string" },
        "requestedAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "linkId", "userId", "requestedAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback or bug report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "type": { "type": "string", "enum": ["bug", "comment", "request_links"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "userId", "type", "content", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A user liking a link",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "linkId": { "type": "string" }
      },
      "required": ["userId", "linkId"]
    },
    "Report": {
      "title": "Report",
      "description": "A user reporting a broken link",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "linkId": { "type": "string" },
        "reportedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "linkId", "reportedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Admin-user communication",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" },
        "type": { "type": "string", "enum": ["admin_to_user", "user_to_admin"] }
      },
      "required": ["id", "senderId", "receiverId", "content", "createdAt", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/links/{linkId}": {
      "schema": "Link",
      "description": "Available premium links"
    },
    "/linkRequests/{requestId}": {
      "schema": "LinkRequest",
      "description": "History of link requests to track usage"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback and bug reports"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages between admin and users"
    },
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "User likes on links"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "User reports on broken links"
    }
  }
}
